{
    "rewrites": [
        {
            "source": "/api.php",
            "destination": "/api.php"
        }
    ],
    "functions": {
        "api.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "headers": [
        {
            "source": "/api.php",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type"
                }
            ]
        }
    ]
}